# Data files — never commit patient data
*.csv
*.parquet
*.db
*.sqlite

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Environment variables and secrets
.env
*.key
credentials.json

# macOS and editor files
.DS_Store
.vscode/
.idea/

# Model artifacts (too large for git)
*.pkl
*.joblib
*.h5

# Allow specific files needed for Streamlit deployment
!models/lightgbm_model.pkl
!data/feature_template.json
!data/feature_defaults.json
!data/feature_modes.json

# Trained models (commit only the deployed one)
models/*
!models/lightgbm_model.pkl

# Data files (commit only deployment-needed JSON, never patient data)
data/*
!data/feature_template.json
!data/feature_defaults.json
!data/feature_modes.json
